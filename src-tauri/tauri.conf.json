{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gestion Jauges",
  "version": "1.0.0",
  "identifier": "fr.seva.gestionjauges",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gestion Jauges",
        "width": 1500,
        "height": 950,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "maximized": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Business",
    "shortDescription": "Gestion du stock, des emprunts et des commandes de jauges.",
    "longDescription": "Application de gestion des jauges pour les collaborateurs et le service Métrologie.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "perMachine",
        "languages": [
          "French"
        ],
        "displayLanguageSelector": false,
        "startMenuFolder": "Gestion Jauges",
        "compression": "lzma"
      }
    }
  }
}
