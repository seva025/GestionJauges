{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gestion Jauges",
  "version": "1.0.0",
  "identifier": "com.joraywyss.gestionjauges",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gestion Jauges — Métrologie",
        "width": 1500,
        "height": 950,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "maximized": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
